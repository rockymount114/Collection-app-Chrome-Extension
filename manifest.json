{
    "manifest_version": 3,
    "name": "Munis Bill Search",
    "version": "1.0",
    "key": "hcjkgljoencobfogkdoohipnpjhpcbnc",
    "description": "Opens and fills Munis bill search from the Collection app",
    "permissions": [
        "tabs",
        "scripting",
        "storage"
    ],
    "host_permissions": [
        "https://munisapp.rockymountnc.gov/*",
        "http://172.20.21.22:8080/*",
        "http://localhost:5000/*"
    ],
    "externally_connectable": {
        "matches": [
            "http://172.20.21.22:8080/*",
            "http://localhost:5000/*",
            "http://127.0.0.1:5000/*"
        ]
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://munisapp.rockymountnc.gov/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_title": "Munis Bill Search",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}